    # A function is typically used to process the commands provided line by line
    def process_commands(commands):
        current_list = []
        for command_line in commands:
            # Split the command into parts (e.g., 'insert 0 5' -> ['insert', '0', '5'])
            parts = command_line.split()
            command_type = parts[0]

            if command_type == 'insert':
                # parts[1] is index, parts[2] is element
                current_list.insert(int(parts[1]), int(parts[2]))
            elif command_type == 'print':
                print(current_list)
            elif command_type == 'remove':
                # parts[1] is element
                current_list.remove(int(parts[1]))
            elif command_type == 'append':
                # parts[1] is element
                current_list.append(int(parts[1]))
            elif command_type == 'sort':
                current_list.sort()
            elif command_type == 'pop':
                current_list.pop()
            elif command_type == 'reverse':
                current_list.reverse()
        
